@page "/"
@using System.Collections.Generic
@using Microsoft.JSInterop
@inject PlaceService PlaceService
@inject IJSRuntime JSRuntime
@inject HttpClient Http

<MudText Typo="Typo.h2" Class="mb-4 serif-text text-center mt-8">尋找避難所</MudText>

@if (_isLocating)
{
    <MudContainer MaxWidth="MaxWidth.Small" Class="d-flex flex-column align-center justify-center my-16 py-16">
        <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" Class="mb-6" />
        <MudText Typo="Typo.h5" Class="serif-text" Color="Color.Primary" Style="font-weight: 500;">正在透過星象儀尋找您的經緯度...</MudText>
        <MudText Typo="Typo.body2" Class="mt-2" Style="color: #707A65;">請允許瀏覽器存取您的位置資訊</MudText>
    </MudContainer>
}
else
{
<MudText Typo="Typo.body1" Class="mb-6 text-center" Style="color: #707A65;">選擇你現在的心情或需求，我們會為你找到最契合的角落。</MudText>

<MudContainer MaxWidth="MaxWidth.Medium" Class="d-flex justify-center mb-6">
    <MudToggleGroup @bind-Value="TransportMode" T="string" Color="Color.Primary" SelectionMode="SelectionMode.SingleSelection" Class="glass-card px-2 py-1">
        <MudToggleItem Value="@("Walking")" Text="🚶 步行 (1km內)" />
        <MudToggleItem Value="@("Cycling")" Text="🚲 騎車 (4km內)" />
    </MudToggleGroup>
</MudContainer>

<MudContainer MaxWidth="MaxWidth.Medium" Class="d-flex justify-center mb-10">
    <MudChipSet T="string" SelectionMode="SelectionMode.MultiSelection" SelectedValues="_selectedTags" SelectedValuesChanged="OnTagsChanged" Class="d-flex justify-center flex-wrap gap-2">
        @foreach (var tag in _availableTags)
        {
            <MudChip T="string" Value="@tag" Color="Color.Primary" Variant="Variant.Outlined" Class="hover-lift px-4 py-2">@tag</MudChip>
        }
    </MudChipSet>
</MudContainer>

@if (_matchedPlaces.Any())
{
    <MudGrid Spacing="4" Class="justify-center">
        @foreach (var place in _matchedPlaces)
        {
            <MudItem xs="12" sm="10" md="6">
                <MudCard Elevation="0" Class="glass-card animate-fade-in mx-auto h-100 d-flex flex-column" Style="max-width: 500px;">
                    <MudCardMedia Image="@place.ImageUrl" Height="220" Style="border-top-left-radius: 16px; border-top-right-radius: 16px;" />
                    <MudCardContent Class="pa-6 flex-grow-1">
                        <div class="d-flex justify-space-between align-center mb-2">
                            <MudText Typo="Typo.h5" Class="serif-text" Color="Color.Primary">@place.Name</MudText>
                            <div class="d-flex align-center gap-2">
                                <div class="vibe-ring" style="--vibe-deg: @(CalculateVibeMatch(place) * 3.6)deg;" title="氛圍契合度">
                                    @(CalculateVibeMatch(place))%
                                </div>
                                <MudChip T="string" Size="Size.Small" Color="Color.Transparent" Style="border: 1px solid #707A65; color: #707A65;">
                                    直線約 @(place.DistanceInMeters) m
                                </MudChip>
                            </div>
                        </div>
                         <MudText Typo="Typo.body2" Class="mb-4" Style="color: #5A6250; line-height: 1.8;">@place.Description</MudText>
                         
                         @if (_showMapId == place.Id)
                         {
                             <div class="animate-fade-in mb-4" style="height: 200px; width: 100%; border-radius: 12px; overflow: hidden; border: 1px solid rgba(122, 157, 84, 0.2);">
                                 <iframe 
                                     width="100%" 
                                     height="100%" 
                                     frameborder="0" 
                                     style="border:0"
                                     src="@($"https://maps.google.com/maps?q={place.Latitude},{place.Longitude}&hl=zh-TW&z=15&output=embed")" 
                                     allowfullscreen>
                                 </iframe>
                             </div>
                         }

                         <div class="mt-auto pt-4 d-flex justify-space-between align-end" style="border-top: 1px dashed rgba(110, 126, 102, 0.3);">
                            <div>
                                @foreach(var tag in place.Tags)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Filled" Class="mr-2 mb-2">@tag</MudChip>
                                }
                            </div>
                            <div class="d-flex gap-2">
                                <MudIconButton Icon="@Icons.Material.Filled.LocationOn" Color="Color.Primary" Size="Size.Small" OnClick="() => ToggleMap(place.Id)" title="預覽地圖" />
                                <MudButton Href="@($"https://www.google.com/maps/dir/?api=1&origin={_userLat},{_userLng}&destination={Uri.EscapeDataString(place.Name)}&destination_place_id={place.Id}&travelmode={(TransportMode == "Walking" ? "walking" : "bicycling")}")" Target="_blank" Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small" Class="mb-1 hover-lift rounded-pill" StartIcon="@Icons.Material.Filled.Navigation">
                                    導航
                                </MudButton>
                            </div>
                         </div>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }
    </MudGrid>

    <div class="text-center mt-12 mb-8 animate-fade-in">
        <MudText Typo="Typo.body1" Class="mb-4" Style="color: #707A65;">不知道大家想吃哪個嗎？</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Secondary" Class="hover-lift px-8 py-3 rounded-pill serif-text" Size="Size.Large" OnClick="PassToGroupVote">
            把選擇權交給好友 (進行盲測投票)
        </MudButton>
    </div>
}
}
@code {
    [Inject] NavigationManager NavManager { get; set; } = default!;
    private List<string> _availableTags = new();
    private IReadOnlyCollection<string> _selectedTags = Array.Empty<string>();
    private List<Place> _matchedPlaces = new();

    private bool _isLocating = true;
    private string? _showMapId;
    private double _userLat = 25.0422; // Default: Taipei Main Station
    private double _userLng = 121.5173; 

    private string _transportMode = "Walking";
    public string TransportMode
    {
        get => _transportMode;
        set
        {
            if (_transportMode != value)
            {
                _transportMode = value;
                RefreshSearch();
            }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await PlaceService.InitializeAsync(Http);
        _availableTags = PlaceService.GetAllTags();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _isLocating)
        {
            try 
            {
                var result = await JSRuntime.InvokeAsync<GeolocationData?>("window.getUserGeolocation");
                if (result != null)
                {
                    _userLat = result.Latitude;
                    _userLng = result.Longitude;
                    
                    // 同步至 Service 供其他頁面（如揪團結果）使用
                    PlaceService.UserLat = _userLat;
                    PlaceService.UserLng = _userLng;
                }
            }
            catch (Exception ex)
            {
                // Log or handle error - fallback to default location
                Console.WriteLine($"Geolocation error: {ex.Message}");
            }
            finally 
            {
                _isLocating = false;
                RefreshSearch();
                StateHasChanged();
            }
        }
    }

    private double CalculateRoughDistance(double lat1, double lon1, double lat2, double lon2)
    {
        var dLat = (lat2 - lat1) * Math.PI / 180.0;
        var dLon = (lon2 - lon1) * Math.PI / 180.0;
        var a = Math.Sin(dLat / 2) * Math.Sin(dLat / 2) + Math.Cos(lat1 * Math.PI / 180.0) * Math.Cos(lat2 * Math.PI / 180.0) * Math.Sin(dLon / 2) * Math.Sin(dLon / 2);
        return 6371000 * (2 * Math.Atan2(Math.Sqrt(a), Math.Sqrt(1 - a)));
    }

    private void OnTagsChanged(IReadOnlyCollection<string> values)
    {
        _selectedTags = values;
        RefreshSearch();
    }

    private void RefreshSearch()
    {
        if (!_isLocating)
        {
            _matchedPlaces = PlaceService.GetMatches(_selectedTags, TransportMode, _userLat, _userLng);
        }
    }

    private void ToggleMap(string id)
    {
        if (_showMapId == id) _showMapId = null;
        else _showMapId = id;
    }

    private void PassToGroupVote()
    {
        PlaceService.SharedCandidates = _matchedPlaces;
        NavManager.NavigateTo("groupvote");
    }

    private int CalculateVibeMatch(Place place)
    {
        if (!_selectedTags.Any()) return 75; // Default vibe
        int matched = place.Tags.Intersect(_selectedTags).Count();
        int percentage = (int)((double)matched / _selectedTags.Count * 100);
        return Math.Clamp(percentage, 60, 99); // Always show at least 60% for a positive feel
    }
    }
}
